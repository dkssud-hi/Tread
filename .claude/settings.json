{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash 'c:/workspace/tread/.claude/hooks/enforce-docs-path.sh'"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash 'c:/workspace/tread/.claude/hooks/check-docs-sync.sh'"
          }
        ]
      }
    ]
  }
}
